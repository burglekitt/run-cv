{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/tmp",
      "!!package.json",
      "!!.npmignore",
      "!!.gitignore",
      "!!**/.github",
      "!!**/.husky",
      "!!.github",
      "!!AGENTS.md"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "plugins": [
    "./plugins/no-date-now.grit",
    "./plugins/no-date-parse.grit",
    "./plugins/no-date-utc.grit",
    "./plugins/no-new-date.grit"
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
